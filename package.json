{
  "name": "espresso-cockpit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "pnpm test && pnpm build && pnpm test:browser:smoke",
    "deploy:tablet": "pnpm build && node scripts/deploy-tablet-skin.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:agent": "PLAYWRIGHT_AGENT_MODE=1 pnpm test:browser:smoke",
    "test:browser:full": "playwright test",
    "test:browser:real": "PLAYWRIGHT_REAL_GATEWAY_URL=${PLAYWRIGHT_REAL_GATEWAY_URL:-} playwright test tests/browser/real-gateway.spec.ts",
    "test:browser:smoke": "playwright test --project=tablet-sm-portrait --grep @smoke",
    "test:browser:update-snapshots": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.91.3",
    "@tanstack/react-router": "^1.168.1",
    "@visx/grid": "3.12.0",
    "@visx/group": "3.12.0",
    "@visx/scale": "3.12.0",
    "@visx/shape": "3.12.0",
    "@visx/visx": "^3.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "ws": "^8.18.3"
  }
}
